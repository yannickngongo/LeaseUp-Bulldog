# ─── LeaseUp Bulldog — Environment Variables ──────────────────────────────────
# LOCAL:      copy this file to .env.local  (git-ignored, never commit secrets)
# PRODUCTION: add each variable in Vercel → Settings → Environment Variables → Redeploy
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ───────────────────────────────────────────────────────────────────
# Find these at: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon-key
# Service role key — used server-side only (middleware plan gating). NEVER expose to browser.
# Find at: supabase.com → your project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service-role-key

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Find at: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
# Find at: dashboard.stripe.com → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Find at: dashboard.stripe.com → Products → each plan's price → Price ID
STRIPE_PRICE_ID_STARTER=price_starter_id_here
STRIPE_PRICE_ID_PRO=price_pro_id_here
STRIPE_PRICE_ID_PORTFOLIO=price_portfolio_id_here
STRIPE_PRICE_ID_MARKETING_ADDON=price_marketing_addon_id_here

# ── Twilio (SMS) ───────────────────────────────────────────────────────────────
# Find at: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
# Set to "1" in development to skip sending real SMS messages
# TWILIO_TEST_MODE=1

# ── Resend (Email) ─────────────────────────────────────────────────────────────
# Find at: resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here
# Optional — defaults to "LeaseUp Bulldog <notifications@resend.dev>"
# Set this after verifying your domain in Resend
# RESEND_FROM_EMAIL=LeaseUp Bulldog <noreply@yourdomain.com>

# ── Anthropic (AI) ─────────────────────────────────────────────────────────────
# Find at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ────────────────────────────────────────────────────────────────────────
# Your production URL — used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Admin email — gets escalation alerts and owner-level access
ADMIN_EMAIL=you@yourdomain.com
NEXT_PUBLIC_ADMIN_EMAIL=you@yourdomain.com
# Secret for authenticating cron job endpoints (generate a random string)
CRON_SECRET=your-random-cron-secret-here

# ── RentCast (Competitor Rent Tracking) ────────────────────────────────────────
# Find at: app.rentcast.io → Account → API
RENTCAST_API_KEY=your_rentcast_api_key_here

# ── Meta / Facebook (Lead Ads) ────────────────────────────────────────────────
# Find at: developers.facebook.com → your app → Webhooks
META_ACCESS_TOKEN=your_meta_access_token_here
META_BUSINESS_ID=your_meta_business_id_here
FACEBOOK_VERIFY_TOKEN=your_custom_verify_token_here

# ── Google Ads (Lead Integration) ─────────────────────────────────────────────
# Find at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_MANAGER_ID=1234567890

# ── Sentry (Error Monitoring) ──────────────────────────────────────────────────
# Find at: sentry.io → your project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# ── Marketing Add-on (Stripe subscription) ───────────────────────────────────
# Comma-separated emails that bypass the Stripe subscription check (testing only).
PRO_OVERRIDE_EMAILS=

# Create these in Stripe Dashboard → Products → "LUB Marketing Add-on":
#   1. Recurring price, $500/month, licensed                       → STRIPE_PRICE_MARKETING_FLAT
#   2. Recurring price, $0.05 per unit, metered, monthly billing   → STRIPE_PRICE_AD_SPEND_METERED
#      (1 unit = $1 of ad spend, so $0.05 per unit = 5% of spend)
STRIPE_PRICE_MARKETING_FLAT=
STRIPE_PRICE_AD_SPEND_METERED=

# Stripe webhook secret — create endpoint at https://your-domain.com/api/billing/webhook
# Listen to: checkout.session.completed, customer.subscription.*, invoice.payment_*
STRIPE_WEBHOOK_SECRET=

# ── Meta Ads (Facebook + Instagram) ──────────────────────────────────────────
# Create a Facebook App at developers.facebook.com → My Apps → Create App (Business type).
# Add products: Marketing API, Facebook Login for Business.
# Under Settings → Basic, copy App ID + App Secret here.
META_APP_ID=
META_APP_SECRET=
# Any random string — also enter this in Meta App → Webhooks → Verify Token
META_VERIFY_TOKEN=
# Required: in Facebook App → Facebook Login → Settings → Valid OAuth Redirect URIs, add:
#   https://your-domain.com/api/integrations/meta/oauth/callback
#   http://localhost:3002/api/integrations/meta/oauth/callback   (for local dev)

# ── Google Ads ───────────────────────────────────────────────────────────────
# Any random string — enter this as the "Key" in Google Ads → Lead Form → Webhook
GOOGLE_WEBHOOK_KEY=

# ── Marketing Add-on launch flag ─────────────────────────────────────────────
# Controls whether the Marketing Add-on is live or shown as "Coming Soon".
# Values: "coming_soon" (default) | "live"
# When "coming_soon":
#   - /marketing renders a Coming Soon page with waitlist signup
#   - /api/campaigns/draft, /api/campaigns/[id]/launch, /api/billing/subscribe return 503
#   - Sidebar shows "Soon" badge, links to /marketing
#   - /pricing and /settings/billing show waitlist forms instead of subscribe buttons
# Flip to "live" once Meta App is set up + you're ready to onboard customers.
NEXT_PUBLIC_MARKETING_ADDON_STATUS=coming_soon

# ── Migration runner (npm run db:migrate) ────────────────────────────────────
# Postgres connection string from Supabase → Project Settings → Database →
# Connection string → URI (use the "Connection pooling" form, port 6543).
# Required for `npm run db:migrate` to apply pending SQL migrations.
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Sentry daily digest cron (optional) ──────────────────────────────────────
# Pulls yesterday's unresolved errors and posts a summary to Slack.
# Skips silently if any of these are missing.
# Get token at sentry.io → User Settings → Auth Tokens (scope: project:read).
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=
# Slack incoming webhook URL (Slack app → Incoming Webhooks → New webhook)
SLACK_WEBHOOK_URL=
